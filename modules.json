{
    "_note": "Modules grouped by category: slash_commands, chat, auto.",
    "modules": {
        "slash_commands": {
            "_note": "Slash command modules  -  register Discord slash commands",
            "script_editor": false,
            "wad_manager": false,
            "server_control": false,
            "player_management": false
        },
        "chat": {
            "_note": "Chat modules  -  relay messages between Discord and SRB2",
            "chat_relay": true,
            "chat_card": {
                "_note": "Available fields: {name}, {node}, {skin}",
                "enabled": true,
                "format": ":skin: {name}"
            },
            "server_chat_card": {
                "_note": "Available fields: none (format only)",
                "enabled": true,
                "format": ":speaking_head: Server"
            },
            "csay_card": {
                "_note": "Available fields: none (format only)",
                "enabled": true,
                "format": "Message"
            },
            "shutdown_card": {
                "_note": "Available fields: {server_name}, {map}, {uptime}, {players}",
                "enabled": true,
                "message": ":red_circle: :robot: srb2dbot is going down"
            }
        },
        "auto": {
            "_note": "Auto modules  -  run automatically from game events",
            "auto_pause": {
                "_note": "Auto-pause the server when no players are connected",
                "enabled": false
            },
            "server_start_card": {
                "enabled": true,
                "message": ":green_circle: :robot: srb2dbot is up"
            },
            "round_start_card": {
                "_note": "Available fields: {gametype}, {map_num}, {map_title}",
                "enabled": true,
                "message": ":map: Map is now {map_title}",
                "thumbnails": true
            },
            "round_end_card": {
                "_note": "Available fields: none (uses fixed format)",
                "enabled": true,
                "thumbnails": true
            },
            "flag_capture_card": false,
            "flag_drop_card": false,
            "flag_pickup_card": false,
            "flag_return_card": false,
            "player_join_card": {
                "_note": "Available fields: {player}, {node}",
                "enabled": true,
                "message":":heavy_plus_sign: {player} has joined the game. (player {node})"
            },
            "player_quit_card": {
                "_note": "Available fields: {player}, {node}, {reason}",
                "enabled": true,
                "message": ":heavy_minus_sign: {player} has left the game. (player {node}) {reason}"
            },
            "kick_player_card": {
                "_note": "Available fields: {player}, {node}, {reason}",
                "enabled": false,
                "message": "{player} was kicked. Reason: {reason} (player {node})"
            },
            "ban_player_card": {
                "_note": "Available fields: {player}, {node}, {reason}",
                "enabled": false,
                "message": "{player} was banned. Reason: {reason} (player {node})"
            }
        }
    }
}
