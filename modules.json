{
    "_note": "Modules grouped by category: slash_commands, chat, auto.",
    "modules": {
        "slash_commands": {
            "_note": "Slash command modules — register Discord slash commands",
            "script_editor": false,
            "wad_manager": false,
            "server_control": false,
            "player_management": false
        },
        "chat": {
            "_note": "Chat modules — relay messages between Discord and SRB2",
            "chat_relay": true,
            "chat_card": true,
            "server_chat_card": true,
            "csay_card": {
                "enabled": true,
                "message": ":loudspeaker: Server Announcement"
            }
        },
        "auto": {
            "_note": "Auto modules — run automatically from game events",
            "server_start_card": {
                "enabled": true,
                "message": ":green_circle: :robot: srb2dbot is up"
            },
            "round_start_card": {
                "_note": "Available fields: {gametype}, {map_num}, {map_title}",
                "enabled": true,
                "message": ":map: Map is now {map_title}",
                "thumbnails": true
            },
            "round_end_card": {
                "_note": "Available fields: {gametype}, {map_num}, {map_title}",
                "enabled": false,
                "message": "{map_num}: {map_title} - {gametype}"
            },
            "flag_capture_card": false,
            "flag_drop_card": false,
            "flag_pickup_card": false,
            "flag_return_card": false,
            "player_join_card": {
                "_note": "Available fields: {player}, {node}",
                "enabled": true,
                "message":"{player} has joined the game. (player {node})"
            },
            "player_quit_card": {
                "_note": "Available fields: {player}, {node}, {reason}",
                "enabled": true,
                "message": "{player} has left the game. (player {node}) {reason}"
            },
            "kick_player_card": {
                "_note": "Available fields: {player}, {node}, {reason}",
                "enabled": false,
                "message": "Player Kicked"
            },
            "ban_player_card": {
                "_note": "Available fields: {player}, {node}, {reason}",
                "enabled": false,
                "message": "Player Banned"
            }
        }
    }
}
